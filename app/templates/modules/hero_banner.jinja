<!-- wp:group {"tagName":"section","anchor":"{{ section.section_id }}","className":"york-hero-banner"} -->
<section class="wp-block-group york-hero-banner" id="{{ section.section_id }}">
  <h2>{{ section.heading }}</h2>
  {% if section.content.eyebrow %}<p class="eyebrow">{{ section.content.eyebrow }}</p>{% endif %}
  {% if section.content.subheading %}<p>{{ section.content.subheading }}</p>{% endif %}
</section>
<!-- /wp:group -->
